{
  "name": "jarvis-desktop",
  "version": "1.0.0",
  "private": true,
  "main": "electron/main.js",
  "description": "JARVIS — AI Desktop Assistant",
  "author": "Hajeera",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "desktop": "concurrently \"next dev -p 3000\" \"wait-on -t 30000 http://localhost:3000 && start msedge --app=http://localhost:3000 --window-size=1400,900 --disable-extensions\"",
    "electron:dev": "concurrently --kill-others \"npm run dev\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:build": "next build && electron-builder"
  },
  "dependencies": {
    "@react-three/drei": "^9.90.0",
    "@react-three/fiber": "^8.15.0",
    "@types/three": "^0.160.0",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.8.0",
    "next": "^14.2.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-tsparticles": "^2.12.2",
    "three": "^0.160.0",
    "tsparticles": "^3.9.1",
    "tsparticles-slim": "^2.12.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^9.2.1",
    "electron": "^41.3.0",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.6.0",
    "wait-on": "^8.0.5"
  },
  "build": {
    "appId": "com.hajeera.jarvis",
    "productName": "JARVIS",
    "files": [
      "electron/**/*",
      ".next/**/*",
      "node_modules/**/*",
      "public/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../",
        "to": "backend",
        "filter": [
          "api.py",
          "jarvis/**/*",
          "static/**/*",
          "!jarvis-frontend/**",
          "!node_modules/**",
          "!.git/**",
          "!__pycache__/**"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "electron/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true
    }
  }
}
