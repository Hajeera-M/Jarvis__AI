# Picovoice Porcupine Access Key (get at https://console.picovoice.ai/)
PICOVOICE_ACCESS_KEY=your_picovoice_access_key_here

# Groq API Key (get at https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# HuggingFace API Token (get at https://huggingface.co/settings/tokens)
HUGGINGFACE_API_TOKEN=your_huggingface_token_here

# PostgreSQL Database URL
DATABASE_URL=postgresql://user:password@localhost/jarvis_db
